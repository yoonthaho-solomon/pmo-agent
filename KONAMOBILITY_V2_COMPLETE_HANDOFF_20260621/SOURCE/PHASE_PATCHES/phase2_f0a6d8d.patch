+        <strong>{numberLabel(model.kpis.missingDays)}</strong>
+      </div>
+      <div>
+        <span>Core tables present</span>
+        <strong>{model.kpis.coreTablesPresent}/{model.kpis.coreTablesTotal}</strong>
+      </div>
+      <Button onClick={onRefresh}>Refresh</Button>
+    </Panel>
+  )
+}
