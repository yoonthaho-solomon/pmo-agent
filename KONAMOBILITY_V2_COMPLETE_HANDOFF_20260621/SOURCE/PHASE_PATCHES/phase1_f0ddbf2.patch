@@ -0,0 +1,33 @@
+'use client'
+
+import Link from 'next/link'
+import { usePathname } from 'next/navigation'
+import styles from '../styles/primitives.module.css'
+
+export const v2Workspaces = [
+  { id: 'data-ops', label: '데이터 운영', href: '/data-ops' },
+  { id: 'vector-workbench', label: '벡터 워크벤치', href: '/vector-workbench' },
+  { id: 'matching-studio', label: '매칭 스튜디오', href: '/matching-studio' },
+] as const
+
+export function WorkspaceTabs() {
+  const pathname = usePathname()
+
+  return (
+    <nav className={styles.tabs} aria-label="KONAMOBILITY V2 작업공간">
+      {v2Workspaces.map((item) => {
+        const active = pathname === item.href
+        return (
+          <Link
+            key={item.id}
+            href={item.href}
+            className={`${styles.tab} ${active ? styles.tabActive : ''}`}
+            aria-current={active ? 'page' : undefined}
+          >
+            {item.label}
+          </Link>
+        )
+      })}
+    </nav>
+  )
+}
diff --git a/app/components/v2/styles/primitives.module.css b/app/components/v2/styles/primitives.module.css
new file mode 100644
index 0000000..98cf11e
--- /dev/null
+++ b/app/components/v2/styles/primitives.module.css
@@ -0,0 +1,387 @@
+.app {
+  min-height: 100dvh;
+  color: var(--km-v2-text-primary);
+  background:
+    radial-gradient(circle at 50% -20%, rgba(67, 214, 239, 0.1), transparent 42%),
+    linear-gradient(180deg, #061018 0%, #050b12 100%);
+}
+
+.header {
+  position: sticky;
+  top: 0;
+  z-index: 50;
+  height: var(--km-v2-header-height);
+  border-bottom: 1px solid var(--km-v2-border-subtle);
+  background: rgba(6, 16, 24, 0.92);
+  backdrop-filter: blur(14px) saturate(140%);
+}
+
+.headerInner {
+  height: 100%;
+  padding: 0 16px;
+  display: grid;
+  grid-template-columns: 260px 1fr 260px;
+  align-items: center;
+  gap: 16px;
+}
+
+.brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 12px;
+  min-width: 0;
+}
+
+.brandMark {
+  width: 34px;
+  height: 34px;
+  border-radius: 10px;
+  display: grid;
+  place-items: center;
+  color: #041015;
+  background: linear-gradient(135deg, var(--km-v2-cyan), var(--km-v2-violet));
+  font-weight: 900;
+  letter-spacing: -0.04em;
+}
+
+.brandText {
+  min-width: 0;
+  display: grid;
+  gap: 2px;
+}
+
+.brandTitle {
+  font-size: 17px;
+  font-weight: 850;
+  line-height: 1;
+  letter-spacing: -0.02em;
+}
+
+.brandSubtitle {
+  color: var(--km-v2-text-muted);
+  font-size: 11px;
+  font-weight: 750;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+}
+
+.tabs {
+  justify-self: center;
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+}
+
+.tab {
+  position: relative;
+  min-width: 132px;
+  height: 40px;
+  padding: 0 16px;
+  display: inline-grid;
+  place-items: center;
+  color: var(--km-v2-text-secondary);
+  border: 1px solid transparent;
+  border-radius: 999px;
+  font-size: 15px;
+  font-weight: 800;
+  transition:
+    color var(--km-v2-motion-standard) var(--km-v2-ease-standard),
+    background var(--km-v2-motion-standard) var(--km-v2-ease-standard),
+    border-color var(--km-v2-motion-standard) var(--km-v2-ease-standard);
+}
+
+.tab:hover {
+  color: var(--km-v2-text-primary);
+  background: rgba(18, 39, 56, 0.72);
+  border-color: var(--km-v2-border-default);
+}
+
+.tabActive {
+  color: var(--km-v2-cyan);
+  background: rgba(67, 214, 239, 0.08);
+  border-color: var(--km-v2-border-strong);
+}
+
+.tabActive::after {
+  content: "";
+  position: absolute;
+  left: 18px;
+  right: 18px;
+  bottom: -13px;
+  height: 2px;
+  border-radius: 999px;
+  background: var(--km-v2-cyan);
+  box-shadow: 0 0 16px rgba(67, 214, 239, 0.45);
+}
+
+.headerRight {
+  justify-self: end;
+  display: inline-flex;
+  align-items: center;
+  gap: 14px;
+  color: var(--km-v2-text-secondary);
+  font-size: 13px;
+}
+
+.statusDot {
+  width: 7px;
+  height: 7px;
+  border-radius: 999px;
+  background: var(--km-v2-green);
+  box-shadow: 0 0 12px rgba(85, 214, 154, 0.45);
+}
+
+.body {
+  min-height: calc(100dvh - var(--km-v2-header-height));
+  padding: 14px;
+}
+
+.workspace {
+  min-height: calc(100dvh - var(--km-v2-header-height) - 28px);
+  display: grid;
+  gap: 12px;
+}
+
+.routeTransition {
+  animation: kmV2Enter var(--km-v2-motion-medium) var(--km-v2-ease-standard);
+}
+
+.panel {
+  background: color-mix(in srgb, var(--km-v2-bg-panel) 96%, transparent);
+  border: 1px solid var(--km-v2-border-subtle);
+  border-radius: var(--km-v2-radius-panel);
+}
+
+.floatingPanel {
+  background: color-mix(in srgb, var(--km-v2-bg-panel-raised) 94%, transparent);
+  border: 1px solid var(--km-v2-border-default);
+  border-radius: var(--km-v2-radius-floating);
+  box-shadow: var(--km-v2-shadow-floating);
+  backdrop-filter: blur(12px);
+}
+
+.interactiveRow {
+  border: 1px solid transparent;
+  border-radius: var(--km-v2-radius-row);
+  transition:
+    background var(--km-v2-motion-standard) var(--km-v2-ease-standard),
+    border-color var(--km-v2-motion-standard) var(--km-v2-ease-standard);
+}
+
+.interactiveRow:hover,
+.interactiveRow[data-selected="true"] {
+  background: var(--km-v2-bg-hover);
+  border-color: var(--km-v2-border-default);
+}
+
+.button {
+  min-height: 38px;
+  padding: 0 14px;
+  border: 1px solid var(--km-v2-border-default);
+  border-radius: var(--km-v2-radius-control);
+  color: var(--km-v2-text-primary);
+  background: var(--km-v2-bg-interactive);
+  font-weight: 750;
+  cursor: pointer;
+  transition:
+    filter var(--km-v2-motion-fast) var(--km-v2-ease-standard),
+    transform var(--km-v2-motion-fast) var(--km-v2-ease-standard),
+    border-color var(--km-v2-motion-fast) var(--km-v2-ease-standard);
+}
+
+.button:hover {
+  border-color: var(--km-v2-border-strong);
+  filter: brightness(1.06);
+}
+
+.button:active {
+  transform: translateY(1px);
+}
+
+.buttonPrimary {
+  color: #041015;
+  border: 0;
+  background: linear-gradient(90deg, var(--km-v2-cyan), var(--km-v2-violet));
+}
+
+.input {
+  min-height: 38px;
+  padding: 0 12px;
+  color: var(--km-v2-text-primary);
+  background: var(--km-v2-bg-interactive);
+  border: 1px solid var(--km-v2-border-default);
+  border-radius: var(--km-v2-radius-control);
+}
+
+.input:focus {
+  outline: 2px solid rgba(67, 214, 239, 0.35);
+  outline-offset: 1px;
+  border-color: var(--km-v2-cyan);
+}
+
+.badge {
+  display: inline-flex;
+  align-items: center;
+  gap: 7px;
+  min-height: 26px;
+  padding: 0 10px;
+  border: 1px solid var(--km-v2-border-default);
+  border-radius: 999px;
+  color: var(--km-v2-text-secondary);
+  background: rgba(18, 39, 56, 0.52);
+  font-size: 12px;
+  font-weight: 750;
+}
+
+.tooltipWrap {
+  position: relative;
+  display: inline-flex;
+}
+
+.tooltip {
+  pointer-events: none;
+  position: absolute;
+  left: 50%;
+  bottom: calc(100% + 8px);
+  z-index: 20;
+  width: max-content;
+  max-width: 260px;
+  transform: translateX(-50%);
+  padding: 8px 10px;
+  color: var(--km-v2-text-primary);
+  background: var(--km-v2-bg-panel-raised);
+  border: 1px solid var(--km-v2-border-default);
+  border-radius: var(--km-v2-radius-control);
+  box-shadow: var(--km-v2-shadow-floating);
+  opacity: 0;
+  transition: opacity var(--km-v2-motion-fast) var(--km-v2-ease-standard);
+  font-size: 12px;
+  line-height: 1.45;
+}
+
+.tooltipWrap:hover .tooltip,
+.tooltipWrap:focus-within .tooltip {
+  opacity: 1;
+}
+
+.stateBox {
+  min-height: 170px;
+  padding: 24px;
+  display: grid;
+  place-items: center;
+  text-align: center;
+  color: var(--km-v2-text-secondary);
+}
+
+.stateBox strong {
+  display: block;
+  margin-bottom: 8px;
+  color: var(--km-v2-text-primary);
+  font-size: 18px;
+}
+
+.skeleton {
+  width: min(420px, 100%);
+  height: 12px;
+  border-radius: 999px;
+  background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.16), rgba(255,255,255,0.06));
+  background-size: 220% 100%;
+  animation: kmV2Skeleton 1.4s linear infinite;
+}
+
+.placeholderHero {
+  padding: 24px;
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 320px;
+  gap: 14px;
+}
+
+.placeholderTitle {
+  margin: 0;
+  color: var(--km-v2-text-primary);
+  font-size: clamp(24px, 3vw, 36px);
+  line-height: 1.08;
+  letter-spacing: -0.045em;
+}
+
+.placeholderText {
+  max-width: 760px;
+  margin: 12px 0 0;
+  color: var(--km-v2-text-secondary);
+  font-size: 15px;
+  line-height: 1.65;
+}
+
+.placeholderMeta {
+  padding: 18px;
+  display: grid;
+  align-content: center;
+  gap: 10px;
+}
+
+@keyframes kmV2Enter {
+  from {
+    opacity: 0;
+    transform: translateY(6px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+@keyframes kmV2Skeleton {
+  to {
+    background-position: -220% 0;
+  }
+}
+
+@media (max-width: 1120px) {
+  .headerInner {
+    grid-template-columns: 210px 1fr auto;
+  }
+
+  .tab {
+    min-width: 110px;
+  }
+
+  .placeholderHero {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (max-width: 860px) {
+  .header {
+    height: auto;
+  }
+
+  .headerInner {
+    min-height: var(--km-v2-header-height);
+    grid-template-columns: 1fr;
+    padding: 12px 14px;
+  }
+
+  .tabs {
+    justify-self: stretch;
+    overflow-x: auto;
+    justify-content: flex-start;
+  }
+
+  .headerRight {
+    justify-self: start;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .routeTransition,
+  .skeleton {
+    animation: none;
+  }
+
+  .tab,
+  .button,
+  .interactiveRow,
+  .tooltip {
+    transition: none;
+  }
+}
